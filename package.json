{
  "name": "amue",
  "version": "0.1.0",
  "private": false,
  "description": "Amue - Nuxt Layer based static blog framework with CLI",
  "bin": {
    "amue": "./bin/amue.mjs"
  },
  "files": [
    ".oxlintrc.json",
    "app",
    "bin",
    "nuxt.config.ts",
    "README.md",
    "uno.config.ts"
  ],
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "preview:amue": "pnpm dlx serve .amue/site -l 4173 -s --no-port-switching",
    "postinstall": "nuxt prepare",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:write": "oxfmt --write .",
    "check": "pnpm lint && pnpm format"
  },
  "dependencies": {
    "@nuxt/content": "^3.7.1",
    "@unocss/nuxt": "^66.5.2",
    "better-sqlite3": "^12.6.2",
    "cac": "^6.7.14",
    "execa": "^9.6.0",
    "nuxt": "^4.3.1",
    "unocss": "^66.5.2",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "oxfmt": "^0.19.0",
    "oxlint": "^1.16.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
